rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - username: string (required) - The user's display name
    //   - avatar: string (required) - The user's avatar URL
    //   - balance: number (required) - The user's balance
    //
    // Collection: lobsters
    // Document ID: {lobsterId}
    // Fields:
    //   - serialNumber: string (required) - The lobster's unique serial number
    //   - rarity: string (required, enum: common, rare, legendary) - The lobster's rarity
    //   - name: string (required) - The lobster's name
    //   - stage: string (required, enum: mini, small, large, super) - The lobster's growth stage
    //   - growthValue: number (required) - The lobster's growth value
    //   - health: number (required) - The lobster's health
    //   - energy: number (required) - The lobster's energy
    //   - imageUrl: string (required) - The lobster's image URL
    //   - ownerId: string (required) - The ID of the user who owns the lobster
    //   - birthDate: string (required) - The date the lobster was born
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "wuxiaowei91@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['username', 'avatar', 'balance']) &&
             data.username is string && data.username.size() > 0 && data.username.size() < 50 &&
             data.avatar is string && data.avatar.size() > 0 &&
             data.balance is number && data.balance >= 0;
    }

    function isValidLobster(data) {
      return data.keys().hasAll(['serialNumber', 'rarity', 'name', 'stage', 'growthValue', 'health', 'energy', 'imageUrl', 'ownerId', 'birthDate']) &&
             data.serialNumber is string &&
             data.rarity in ['common', 'rare', 'legendary'] &&
             data.name is string && data.name.size() > 0 &&
             data.stage in ['mini', 'small', 'large', 'super'] &&
             data.growthValue is number &&
             data.health is number &&
             data.energy is number &&
             data.imageUrl is string &&
             data.ownerId is string &&
             data.birthDate is string;
    }

    function isValidPost(data) {
      return data.keys().hasAll(['userId', 'user', 'avatar', 'content', 'likes', 'comments', 'time']) &&
             data.userId is string &&
             data.user is string &&
             data.avatar is string &&
             data.content is string && data.content.size() > 0 && data.content.size() < 2000 &&
             data.likes is list &&
             data.comments is list &&
             data.time is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    match /lobsters/{lobsterId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidLobster(request.resource.data) && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && isValidLobster(request.resource.data) && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPost(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && isValidPost(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
